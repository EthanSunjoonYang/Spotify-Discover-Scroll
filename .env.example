# Spotify OAuth app credentials - create an app at
# https://developer.spotify.com/dashboard and add
# http://localhost:3000/api/auth/callback/spotify (and your production URL's
# equivalent) as a Redirect URI.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Supabase project used for user tokens, the candidate pool, history, and
# suppressed-artist state. See src/lib/supabase.ts for schema expectations.
SUPABASE_URL=
SUPABASE_KEY=
